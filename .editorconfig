# Indica que este é o arquivo de configuração raiz
root = true

# Configurações globais para todos os arquivos
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# Configurações específicas para arquivos Java (padrão Spring)
[*.java]
indent_size = 4
continuation_indent_size = 8

# Configurações para arquivos de configuração (YAML/JSON/XML)
[*.{yml,yaml,json,xml}]
indent_size = 2

# Configurações para arquivos Markdown
[*.md]
trim_trailing_whitespace = false
